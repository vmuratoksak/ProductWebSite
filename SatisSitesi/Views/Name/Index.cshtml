@using SatisSitesi.Models.ViewModels
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject IStringLocalizer<SharedResource> Localizer
@model NameIndexViewModel
@{
    ViewData["Title"] = Localizer["Name_Management"];
}

<h2>@Localizer["Name_List"]</h2>

<a asp-action="Add" class="btn btn-success mb-3">@Localizer["New_Name"]</a>

<form method="get" class="mb-3">
    <input type="text" name="search" value="@Model.Search" placeholder="@Localizer["Search_Name"]" />
    <button type="submit" class="btn btn-primary">@Localizer["Search"]</button>
</form>

<table class="table table-dark">
    <tr>
        <th>@Localizer["Name"]</th>
        <th>@Localizer["Created_At"]</th>
        <th>@Localizer["Updated_At"]</th>
        <th>@Localizer["Action"]</th>
    </tr>

    @foreach (var item in Model.Names)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">@Localizer["Edit"]</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">@Localizer["Delete"]</a>
            </td>
        </tr>
    }
</table>

<div>
    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        <a asp-action="Index" asp-route-page="@i" asp-route-search="@Model.Search"
           class="btn btn-secondary @(i == Model.CurrentPage ? "active" : "")">
            @i
        </a>
    }
</div>
