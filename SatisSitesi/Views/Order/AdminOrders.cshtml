@model SatisSitesi.Application.Models.OrderIndexModel
@using Microsoft.Extensions.Localization
@using SatisSitesi.Application.Interfaces.Services
@using SatisSitesi.Resources
@inject IStringLocalizer<SharedResource> Localizer
@inject ICurrencyService CurrencyService
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    ViewData["Title"] = Localizer["All_Orders_Admin"];
}

<h2 class="fw-bold mb-4">📦 @Localizer["All_Orders"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model.Orders == null || !Model.Orders.Any())
{
    <div class="alert alert-info">@Localizer["Orders_Empty"]</div>
    ViewData["Title"] = Localizer["My_Orders"];
}

<h2 class="fw-bold mb-4">@Localizer["My_Orders"]</h2>

<form method="get" class="mb-4 d-flex gap-2">
    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="@Localizer["Search"] (Sipariş ID)" style="max-width:300px;" />
    
    <select name="sortBy" class="form-select" style="max-width:200px;">
        <option value="Newest" selected="@(Model.SortBy == "Newest")">@Localizer["Newest"]</option>
        <option value="Oldest" selected="@(Model.SortBy == "Oldest")">@Localizer["Oldest"]</option>
        <option value="TotalDesc" selected="@(Model.SortBy == "TotalDesc")">@Localizer["TotalDesc"]</option>
        <option value="TotalAsc" selected="@(Model.SortBy == "TotalAsc")">@Localizer["TotalAsc"]</option>
    </select>

    <button type="submit" class="btn btn-primary">@Localizer["Search"]</button>
</form>

@if (Model.Orders == null || !Model.Orders.Any())
{
    <div class="alert alert-warning">
        @Localizer["Orders_Empty"]
    </div>
}
else
{
    foreach (var order in Model.Orders)
    {
        <div class="card shadow-lg mb-4"
             style="background:#1e293b;color:#e2e8f0;border:none;border-radius:18px;">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">

                    <div>
                        <h6 class="text-secondary mb-1">
                            @Localizer["Order_Date"]
                        </h6>
                        <h5 class="fw-bold mb-2">
                            @order.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")
                        </h5>

                        <div class="small text-muted mb-2">ID: @order.Id</div>

                        @if (order.Status == "Bekliyor")
                        {
                            <span class="badge bg-warning text-dark">@Localizer["Pending"]</span>
                        }
                        else if (order.Status == "Onaylandı")
                        {
                            <span class="badge bg-success">@Localizer["Approved"]</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Localizer["Cancelled"]</span>
                        }
                    </div>

                    <div class="text-end">
                        <h6 class="text-secondary mb-1">
                            @Localizer["Total_Amount"]
                        </h6>
                        <h4 class="fw-bold text-success mb-3">
                            @CurrencyService.GetFormattedPrice(order.TotalAmount)
                        </h4>
                        
                        <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center gap-2 justify-content-end">
                            <input type="hidden" name="orderId" value="@order.Id" />
                            <select name="status" class="form-select form-select-sm" style="width: auto;">
                                <option value="Bekliyor" selected="@(order.Status == "Bekliyor" ? "selected" : null)">@Localizer["Pending"]</option>
                                <option value="Onaylandı" selected="@(order.Status == "Onaylandı" ? "selected" : null)">@Localizer["Approved"]</option>
                                <option value="İptal Edildi" selected="@(order.Status == "İptal Edildi" ? "selected" : null)">@Localizer["Cancelled"]</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">@Localizer["Update"]</button>
                        </form>
                    </div>

                </div>

                <hr style="border-color:#334155;" />

                <div class="mt-3">

                    @foreach (var item in order.Items)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <div>
                                <span class="fw-semibold">
                                    @item.GetLocalizedName(currentCulture, Localizer)
                                </span>
                            </div>

                            <div class="text-end text-info">
                                @item.Quantity x @CurrencyService.GetFormattedPrice(item.Price)
                            </div>

                        </div>
                    }

                </div>

            </div>
        </div>
    }
}

@if (Model.TotalPages > 1)
{
    <div class="mt-4">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="MyOrders" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy"
               class="btn btn-secondary @(i == Model.CurrentPage ? "active" : "")">
                @i
            </a>
        }
    </div>
}
