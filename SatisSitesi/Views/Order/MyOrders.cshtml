@model List<SatisSitesi.Models.Entities.OrderEntity>
@using SatisSitesi.Services.Interfaces
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject ICurrencyService CurrencyService
@inject IStringLocalizer<SharedResource> Localizer

@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    ViewData["Title"] = Localizer["My_Orders"];
}

<h2 class="fw-bold mb-4">@Localizer["My_Orders"]</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        @Localizer["Orders_Empty"]
    </div>
}
else
{
    foreach (var order in Model)
    {
        <div class="card shadow-lg mb-4"
             style="background:#1e293b;color:#e2e8f0;border:none;border-radius:18px;">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">

                    <div>
                        <h6 class="text-secondary mb-1">
                            @Localizer["Order_Date"]
                        </h6>
                        <h5 class="fw-bold mb-2">
                            @order.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")
                        </h5>

                        @if (order.Status == "Bekliyor")
                        {
                            <span class="badge bg-warning text-dark">@Localizer["Pending"]</span>
                        }
                        else if (order.Status == "Onaylandı")
                        {
                            <span class="badge bg-success">@Localizer["Approved"]</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Localizer["Cancelled"]</span>
                        }
                    </div>

                    <div class="text-end">
                        <h6 class="text-secondary mb-1">
                            @Localizer["Total_Amount"]
                        </h6>
                        <h4 class="fw-bold text-success">
                            @CurrencyService.GetFormattedPrice(order.TotalAmount)
                        </h4>
                    </div>

                </div>

                <hr style="border-color:#334155;" />

                <div class="mt-3">

                    @foreach (var item in order.Items)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <div>
                                <span class="fw-semibold">
                                    @item.GetLocalizedName(currentCulture, Localizer)
                                </span>
                            </div>

                            <div class="text-end text-info">
                                @item.Quantity x @CurrencyService.GetFormattedPrice(item.Price)
                            </div>

                        </div>
                    }

                </div>

            </div>
        </div>
    }
}
