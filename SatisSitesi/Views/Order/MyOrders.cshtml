@model SatisSitesi.Application.Models.OrderIndexModel
@using SatisSitesi.Application.Interfaces.Services
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject ICurrencyService CurrencyService
@inject IStringLocalizer<SharedResource> Localizer
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    ViewData["Title"] = Localizer["My_Orders"];
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">🛍️ @Localizer["My_Orders"]</h1>
        <p class="page-subtitle">@Localizer["Recent_Orders"]</p>
    </div>
    <!-- Integrated Search -->
    <div class="d-flex gap-3 align-items-center flex-wrap">
        <form method="get" class="d-flex gap-2 align-items-center">
            <div class="search-bar" style="background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255,255,255,0.05); min-width: 250px;">
                <i class="bi bi-search text-secondary"></i>
                <input type="text" name="search" value="@Model.Search" placeholder="Sipariş ID ara..." />
            </div>
            <select name="sortBy" class="form-select bg-dark text-light border-secondary" style="width: 160px; font-size: 0.875rem; border-radius: 10px;">
                <option value="Newest" selected="@(Model.SortBy == "Newest")">@Localizer["Newest"]</option>
                <option value="Oldest" selected="@(Model.SortBy == "Oldest")">@Localizer["Oldest"]</option>
                <option value="TotalDesc" selected="@(Model.SortBy == "TotalDesc")">@Localizer["TotalDesc"]</option>
                <option value="TotalAsc" selected="@(Model.SortBy == "TotalAsc")">@Localizer["TotalAsc"]</option>
            </select>
            <button type="submit" class="btn-primary" style="border-radius: 10px; padding: 0.6rem 1.25rem;">@Localizer["Search"]</button>
        </form>
    </div>
</div>

@if (Model.Orders == null || !Model.Orders.Any())
{
    <div class="saas-card text-center py-5 animate-fade-in" style="background: rgba(30, 41, 59, 0.4); border: 1px dashed rgba(255,255,255,0.1); border-radius: 24px;">
        <div class="mb-4" style="font-size: 4rem; opacity: 0.2;">
            <i class="bi bi-cart-x"></i>
        </div>
        <h3 class="fw-bold mb-2">@Localizer["Orders_Empty"]</h3>
        <p class="text-secondary mb-5 mx-auto" style="max-width: 400px; font-size: 0.95rem; line-height: 1.6;">
            Henüz hiç siparişiniz bulunmuyor. Mağazamızdaki harika ürünlere göz atarak ilk siparişinizi hemen oluşturabilirsiniz!
        </p>
        <a asp-controller="Product" asp-action="Index" class="btn-auth-primary px-5 py-3 d-inline-flex align-items-center gap-3" style="text-decoration: none; border-radius: 16px;">
            <i class="bi bi-shop fs-5"></i> 
            <span style="font-weight: 600;">@Localizer["Products"]</span>
        </a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var order in Model.Orders)
        {
            <div class="saas-card p-0 overflow-hidden">
                <div class="p-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <!-- Left: Date + Status -->
                        <div>
                            <span class="text-secondary" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em;">@Localizer["Order_Date"]</span>
                            <div style="font-weight: 600; font-size: 1rem; margin-top: 2px;">
                                @order.CreatedAt.ToString("dd MMM yyyy — HH:mm")
                            </div>
                            <div class="text-secondary mt-1" style="font-size: 0.78rem;">ID: @order.Id</div>
                            <div class="mt-2">
                                @if (order.Status == "Bekliyor")
                                {
                                    <span class="badge" style="background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); padding: 5px 10px; border-radius: 8px;">
                                        <i class="bi bi-clock me-1"></i>@Localizer["Pending"]
                                    </span>
                                }
                                else if (order.Status == "Onaylandı")
                                {
                                    <span class="badge" style="background: rgba(16,185,129,0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.3); padding: 5px 10px; border-radius: 8px;">
                                        <i class="bi bi-check-circle me-1"></i>@Localizer["Approved"]
                                    </span>
                                }
                                else if (order.Status == "Yolda")
                                {
                                    <span class="badge" style="background: rgba(14,165,233,0.15); color: #0ea5e9; border: 1px solid rgba(14,165,233,0.3); padding: 5px 10px; border-radius: 8px;">
                                        <i class="bi bi-truck me-1"></i>@Localizer["Shipped"]
                                    </span>
                                }
                                else if (order.Status == "İletildi")
                                {
                                    <span class="badge" style="background: rgba(37,99,235,0.15); color: #2563eb; border: 1px solid rgba(37,99,235,0.3); padding: 5px 10px; border-radius: 8px;">
                                        <i class="bi bi-check2-all me-1"></i>@Localizer["Delivered"]
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); padding: 5px 10px; border-radius: 8px;">
                                        <i class="bi bi-x-circle me-1"></i>@Localizer["Cancelled"]
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Right: Total + Detail link -->
                        <div class="text-end">
                            <span class="text-secondary" style="font-size: 0.78rem;">@Localizer["Total_Amount"]</span>
                            <div style="font-size: 1.4rem; font-weight: 700; color: #4ade80; margin-top: 2px;">
                                @CurrencyService.GetFormattedPrice(order.TotalAmount)
                            </div>
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn-secondary mt-2 px-3 py-1" style="font-size: 0.8rem; text-decoration: none; border: none;">
                                @Localizer["Action"] <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Items -->
                    <div class="mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var item in order.Items)
                            {
                                <div class="d-flex align-items-center gap-2" style="background: var(--bg-main); border-radius: 8px; padding: 6px 10px;">
                                    <span style="font-size: 0.85rem; font-weight: 500;">@item.GetLocalizedName(currentCulture, Localizer)</span>
                                    <span class="text-secondary" style="font-size: 0.78rem;">×@item.Quantity</span>
                                    <span style="font-size: 0.82rem; color: #60a5fa;">@CurrencyService.GetFormattedPrice(item.Price * item.Quantity)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <div class="d-flex gap-1">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-action="MyOrders" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy"
                       class="btn-secondary px-3 py-1 text-secondary" style="font-size: 0.875rem; border: none;">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="MyOrders" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy"
                       class="btn-secondary px-3 py-1 @(i == Model.CurrentPage ? "" : "text-secondary")"
                       style="font-size: 0.875rem; border: none; @(i == Model.CurrentPage ? "background-color: rgba(37,99,235,0.15); color: var(--primary);" : "")">
                        @i
                    </a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-action="MyOrders" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy"
                       class="btn-secondary px-3 py-1 text-secondary" style="font-size: 0.875rem; border: none;">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        </div>
    }
}
