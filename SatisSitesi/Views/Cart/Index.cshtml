@model List<SatisSitesi.Models.ViewModels.CartViewModel>
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@using SatisSitesi.Services.Interfaces
@inject IStringLocalizer<SharedResource> Localizer
@inject ICurrencyService CurrencyService

@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
}

<h2 class="fw-bold mb-4">🛒 @Localizer["Cart"]</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        @Localizer["Cart_Empty"]
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Ürün</th>
                <th>Fiyat</th>
                <th>Adet</th>
                <th>Toplam</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.GetLocalizedName(currentCulture, Localizer)</td>
                    <td>@CurrencyService.GetFormattedPrice(item.Price)</td>
                    <td>
                        <a asp-action="Decrease" asp-route-id="@item.Id" class="btn btn-warning btn-sm">-</a>
                        @item.Quantity
                        <a asp-action="Increase" asp-route-id="@item.Id" class="btn btn-success btn-sm">+</a>
                    </td>
                    <td>@CurrencyService.GetFormattedPrice(item.TotalPrice)</td>
                    <td>
                        <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end mt-3">
        <a asp-controller="Order" asp-action="Checkout" class="btn btn-success">
            @Localizer["Confirm_Cart"]
        </a>
    </div>
}
