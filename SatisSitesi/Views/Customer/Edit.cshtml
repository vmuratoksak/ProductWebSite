@using SatisSitesi.Domain.Entities
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject IStringLocalizer<SharedResource> Localizer
@model UserEntity

@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title"><i class="bi bi-pencil-square me-2 text-primary"></i> Müşteri Düzenle</h1>
        <p class="page-subtitle"><strong>@Model.Username</strong> kullanıcısının bilgilerini güncelleyin</p>
    </div>
</div>

<div class="saas-card p-4 mx-auto" style="max-width: 600px; border-radius: 24px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Password" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="mb-4">
            <label class="form-label fw-bold text-secondary small text-uppercase mb-2">@Localizer["Username"]</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">
                    <i class="bi bi-person"></i>
                </span>
                <input asp-for="Username" class="form-control bg-dark text-light border-secondary border-opacity-25" style="border-radius: 0 12px 12px 0; padding: 0.75rem;" />
            </div>
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold text-secondary small text-uppercase mb-2">@Localizer["User_Email"]</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">
                    <i class="bi bi-envelope"></i>
                </span>
                <input asp-for="Email" class="form-control bg-dark text-light border-secondary border-opacity-25" style="border-radius: 0 12px 12px 0; padding: 0.75rem;" />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold text-secondary small text-uppercase mb-2">Rol</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">
                    <i class="bi bi-shield-check"></i>
                </span>
                <select asp-for="Role" class="form-select bg-dark text-light border-secondary border-opacity-25" style="border-radius: 0 12px 12px 0; padding: 0.75rem;">
                    <option value="Admin">Admin (Yönetici)</option>
                    <option value="User">User (Müşteri)</option>
                </select>
            </div>
        </div>

        <div class="d-flex gap-3 mt-5">
            <button type="submit" class="btn-primary flex-grow-1" style="border-radius: 12px; padding: 0.8rem;">
                <i class="bi bi-check2-circle me-2"></i>Kaydet
            </button>
            <a asp-action="Index" class="btn-secondary flex-grow-1 text-center" style="border-radius: 12px; padding: 0.8rem; text-decoration: none;">
                Vazgeç
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
