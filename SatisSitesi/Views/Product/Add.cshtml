@using SatisSitesi.Models.Entities
@model ProductEntity
@inject Microsoft.Extensions.Localization.IStringLocalizer<SatisSitesi.Resources.SharedResource> Localizer

<h2>@Localizer["Add_New_Product"]</h2>

<form method="post">
    <!-- TR (Base Data) -->
    <div class="card mb-3 border-primary">
        <div class="card-header bg-primary text-white fw-bold">🇹🇷 Türkçe (@Localizer["Base_Data"])</div>
        <div class="card-body">
            <div class="mb-3">
                <label>@Localizer["Product_Name"]</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label>@Localizer["Description_Label"]</label>
                <textarea asp-for="Description" class="form-control" required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>@Localizer["Price"]</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label>@Localizer["Stock"]</label>
                    <input asp-for="Stock" type="number" class="form-control" required />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-100 mt-4">💾 @Localizer["Save"]</button>
</form>
