@model SatisSitesi.Application.Models.ProductIndexModel
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@using SatisSitesi.Application.Interfaces.Services
@inject IStringLocalizer<SharedResource> Localizer
@inject ICurrencyService CurrencyService

@{
    ViewData["Title"] = Localizer["Products"];
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
}

<h2 class="fw-bold mb-4">📦 @Localizer["Products"]</h2>

@if (Context.Session.GetString("UserRole") == "Admin")
{
    <div class="mb-4">
        <a asp-controller="Product" asp-action="Add" class="btn btn-success">
            ➕ @Localizer["Add_New_Product"]
        </a>
    </div>
}

<form method="get" class="mb-4 d-flex flex-wrap gap-2 align-items-center">
    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="@Localizer["Search_Name"]" style="max-width:250px;" />
    
    <input type="number" step="0.01" name="minPrice" value="@Model.MinPrice" class="form-control" placeholder="Min ₺" style="max-width:100px;" />
    
    <input type="number" step="0.01" name="maxPrice" value="@Model.MaxPrice" class="form-control" placeholder="Max ₺" style="max-width:100px;" />

    <div class="form-check text-white ms-2">
        <input class="form-check-input" type="checkbox" name="inStockOnly" value="true" id="inStockCheck" @(Model.InStockOnly ? "checked" : "")>
        <label class="form-check-label" for="inStockCheck">
            @Localizer["Stock"] > 0
        </label>
    </div>

    <select name="sortBy" class="form-select ms-2" style="max-width:200px;">
        <option value="Newest" selected="@(Model.SortBy == "Newest")">@Localizer["Newest"]</option>
        <option value="Oldest" selected="@(Model.SortBy == "Oldest")">@Localizer["Oldest"]</option>
        <option value="PriceAsc" selected="@(Model.SortBy == "PriceAsc")">@Localizer["Price_Asc"]</option>
        <option value="PriceDesc" selected="@(Model.SortBy == "PriceDesc")">@Localizer["Price_Desc"]</option>
    </select>

    <button type="submit" class="btn btn-primary ms-2">@Localizer["Search"]</button>
</form>

<div class="row">
    @if(Model.Products == null || !Model.Products.Any())
    {
        <div class="col-12"><p class="text-warning">Sonuç bulunamadı.</p></div>
    }
    else
    {
        @foreach (var item in Model.Products)
        {
            <div class="col-md-3 mb-4">
                <div class="card p-4 shadow-lg h-100"
                     style="background:#1e293b;color:#e2e8f0;border-radius:15px;">

                    <h4>@item.GetLocalizedName(currentCulture, Localizer)</h4>
                    <p class="text-secondary small mb-3 flex-grow-1">@item.GetLocalizedDescription(currentCulture, Localizer)</p>

                    <span class="badge bg-info mb-2 w-50">
                        @Localizer["Stock"]: @item.Stock
                    </span>

                    <h5 class="text-success mb-3">
                        @CurrencyService.GetFormattedPrice(item.Price)
                    </h5>

                    @* USER NOT LOGGED IN *@
                    @if (Context.Session.GetString("UserId") == null)
                    {
                        <a asp-controller="Auth" asp-action="Login"
                           class="btn btn-warning btn-sm w-100 mt-auto">
                            @Localizer["Login"]
                        </a>
                    }

                    @* ADMIN *@
                    else if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <div class="d-flex flex-column gap-2 mt-auto">

                            <div class="d-flex gap-2">
                                <a asp-controller="Product" asp-action="IncreaseStock" asp-route-id="@item.Id"
                                   class="btn btn-success btn-sm w-50">
                                    ➕ @Localizer["Increase_Stock"]
                                </a>

                                <a asp-controller="Product" asp-action="DecreaseStock" asp-route-id="@item.Id"
                                   class="btn btn-secondary btn-sm w-50">
                                    ➖ @Localizer["Decrease_Stock"]
                                </a>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm w-50">
                                    ✏️ @Localizer["Edit"]
                                </a>

                                <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm w-50">
                                    🗑 @Localizer["Delete"]
                                </a>
                            </div>

                        </div>
                    }

                    @* NORMAL USER *@
                    else
                    {
                        if (item.Stock > 0)
                        {
                            <a asp-controller="Cart" asp-action="Add" asp-route-productId="@item.Id"
                               class="btn btn-primary btn-sm w-100 mt-auto">
                                🛒 @Localizer["Add_To_Cart"]
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm w-100 mt-auto" disabled>
                                @Localizer["Out_Of_Stock"]
                            </button>
                        }
                    }

                </div>
            </div>
        }
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="mt-4">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="Index" 
               asp-route-page="@i" 
               asp-route-search="@Model.Search" 
               asp-route-sortBy="@Model.SortBy"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               asp-route-inStockOnly="@Model.InStockOnly"
               class="btn btn-secondary @(i == Model.CurrentPage ? "active" : "")">
                @i
            </a>
        }
    </div>
}
