@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject IStringLocalizer<SharedResource> Localizer
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture;
    var isRtl = currentCulture.TextInfo.IsRightToLeft;
    var supportedCultures = new[] { "tr", "en", "de", "fr", "ar" };
}
<!DOCTYPE html>
<html lang="@currentCulture.Name" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyShop</title>
    
    @* SEO Tags *@
    @foreach(var cult in supportedCultures)
    {
        <link rel="alternate" hreflang="@cult" href="@Url.Action(ViewContext.RouteData.Values["action"]!.ToString(), ViewContext.RouteData.Values["controller"]!.ToString(), new { culture = cult })" />
    }
    <link rel="alternate" hreflang="x-default" href="@Url.Action(ViewContext.RouteData.Values["action"]!.ToString(), ViewContext.RouteData.Values["controller"]!.ToString(), new { culture = "tr" })" />
    
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    @if(isRtl)
    {
        <link href="~/css/rtl.css" rel="stylesheet" />
    }

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #020617);
            color: #e2e8f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link-custom {
            color: #cbd5e1;
            font-weight: 500;
            transition: 0.3s ease;
        }

            .nav-link-custom:hover {
                color: #38bdf8;
                transform: translateY(-2px);
            }

        .user-badge {
            background: rgba(56,189,248,0.15);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 14px;
        }

        .btn-danger {
            border-radius: 20px;
        }

        .dashboard-wrapper {
            margin-top: 60px;
        }

        .card-modern {
            background: rgba(30,41,59,0.7);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            transition: 0.3s;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

            .card-modern:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            }

            .card-modern h3 {
                font-size: 32px;
                color: #38bdf8;
            }

        #google_translate_element {
            margin-right: 15px;
        }

    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4 py-3">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🛍 MyShop</a>

        <div class="ms-auto d-flex gap-4 align-items-center">

            <!-- LANGUAGE SELECTOR -->
            @await Component.InvokeAsync("LanguageSelector")

            @if (Context.Session.GetString("UserEmail") != null)
            {
                <a asp-controller="Name" asp-action="Index" class="nav-link-custom">@Localizer["Name_Management"]</a>
                <a asp-controller="Product" asp-action="Index" class="nav-link-custom">@Localizer["Products"]</a>
                <a asp-controller="Cart" asp-action="Index" class="nav-link-custom">@Localizer["Cart"]</a>
                <a asp-controller="Order" asp-action="MyOrders" class="nav-link-custom">@Localizer["My_Orders"]</a>
                
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a asp-controller="Order" asp-action="AdminOrders" class="nav-link-custom text-warning">📦 @Localizer["Manage_Orders"]</a>
                }

                <a asp-controller="Home" asp-action="Technologies" class="nav-link-custom">@Localizer["Technologies"]</a>
                <a asp-controller="Home" asp-action="Privacy" class="nav-link-custom">@Localizer["Privacy"]</a>

                <span class="user-badge">
                    👋 @Context.Session.GetString("Username")
                </span>

                <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger btn-sm px-3">
                    @Localizer["Logout"]
                </a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-sm px-3">@Localizer["Login"]</a>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-success btn-sm px-3">@Localizer["Register"]</a>
            }
        </div>
    </nav>

    <div class="container dashboard-wrapper">
        @RenderBody()
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
