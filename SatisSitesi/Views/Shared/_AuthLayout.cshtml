@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Localization
@using SatisSitesi.Resources
@inject IStringLocalizer<SharedResource> Localizer
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyShop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body.auth-body {
            margin: 0;
            background: linear-gradient(135deg, #0f172a, #020617);
            min-height: 100vh;
            color: #e2e8f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link-custom {
            color: #cbd5e1;
            font-weight: 500;
            text-decoration: none;
            transition: 0.3s ease;
        }

            .nav-link-custom:hover {
                color: #38bdf8;
                transform: translateY(-2px);
            }

        .user-badge {
            background: rgba(56,189,248,0.15);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 14px;
        }

        .auth-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 85vh;
        }

        .auth-card {
            background: #1e293b;
            padding: 40px;
            border-radius: 15px;
            width: 400px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
            color: white;
        }

        .form-control {
            background-color: #0f172a;
            border: 1px solid #334155;
            color: white;
        }

        .btn-auth {
            background-color: #2563eb;
            border: none;
        }

            .btn-auth:hover {
                background-color: #1d4ed8;
            }

    </style>
</head>

<body class="auth-body">

    <nav class="navbar navbar-expand-lg navbar-dark px-4 py-3">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
            ?? MyShop
        </a>

        <div class="ms-auto d-flex gap-4 align-items-center">

            <!-- LANGUAGE SELECTOR -->
            @await Component.InvokeAsync("LanguageSelector")

            <a asp-controller="Name" asp-action="Index" class="nav-link-custom">
                @Localizer["Name_Management"]
            </a>

            <a asp-controller="Product" asp-action="Index" class="nav-link-custom">
                @Localizer["Products"]
            </a>

            <a asp-controller="Cart" asp-action="Index" class="nav-link-custom">
                @Localizer["Cart"]
            </a>

            <a asp-controller="Order" asp-action="MyOrders" class="nav-link-custom">
                @Localizer["My_Orders"]
            </a>

            <a asp-controller="Home" asp-action="Technologies" class="nav-link-custom">
                @Localizer["Technologies"]
            </a>

            <a asp-controller="Home" asp-action="Privacy" class="nav-link-custom">
                @Localizer["Privacy"]
            </a>

            @if (Context.Session.GetString("Username") == null)
            {
                <a class="btn btn-primary btn-sm px-3"
                   asp-controller="Auth"
                   asp-action="Login">
                    @Localizer["Login"]
                </a>

                <a class="btn btn-success btn-sm px-3"
                   asp-controller="Auth"
                   asp-action="Register">
                    @Localizer["Register"]
                </a>
            }
            else
            {
                <span class="user-badge">
                    ?? @Context.Session.GetString("Username")
                </span>

                <a class="btn btn-danger btn-sm px-3"
                   asp-controller="Auth"
                   asp-action="Logout">
                    @Localizer["Logout"]
                </a>
            }

        </div>
    </nav>

    <div class="auth-container">
        @RenderBody()
    </div>

    <!-- BOOTSTRAP JS IS REQUIRED FOR DROPDOWN TO WORK -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- ALERT SYSTEM -->
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: '@Html.Raw(TempData["Success"])',
                showConfirmButton: false,
                timer: 1200
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Hata',
                text: '@Html.Raw(TempData["Error"])',
                confirmButtonColor: '#ef4444'
            });
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            Swal.fire({
                icon: 'info',
                title: '@Html.Raw(TempData["Info"])',
                timer: 1200,
                showConfirmButton: false
            });
        </script>
    }

</body>
</html>
