@model List<SatisSitesi.Domain.Entities.ContactMessageEntity>
@{
    ViewData["Title"] = "İletişim Mesajları";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-white mb-1">İletişim Mesajları</h2>
            <p class="text-secondary small mb-0">Ziyaretçilerden gelen tüm mesajları buradan yönetebilirsiniz.</p>
        </div>
        <div class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
            Toplam @Model.Count Mesaj
        </div>
    </div>

    <div class="saas-card p-0 overflow-hidden border-0 shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-dark-soft">
                    <tr>
                        <th class="ps-4 py-3 text-secondary smaller fw-bold text-uppercase">Tarih</th>
                        <th class="py-3 text-secondary smaller fw-bold text-uppercase">Gönderen</th>
                        <th class="py-3 text-secondary smaller fw-bold text-uppercase">Konu</th>
                        <th class="py-3 text-secondary smaller fw-bold text-uppercase">Mesaj</th>
                        <th class="pe-4 py-3 text-end text-secondary smaller fw-bold text-uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">
                                <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                Henüz hiç mesaj yok.
                            </td>
                        </tr>
                    }
                    @foreach (var msg in Model)
                    {
                        <tr id="row-@msg.Id">
                            <td class="ps-4 small text-secondary">@msg.SentAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="fw-bold">@msg.FullName</div>
                                <div class="text-secondary smaller">@msg.Email</div>
                                <div class="text-secondary smaller">@msg.Phone</div>
                            </td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary smaller">@msg.Subject</span>
                            </td>
                            <td>
                                <div class="text-truncate text-secondary small" style="max-width: 300px;" title="@msg.Message">
                                    @msg.Message
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                <button class="icon-btn text-info" onclick="viewMessage('@msg.Id', '@msg.FullName', '@msg.Message')" title="Görüntüle">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="icon-btn text-danger" onclick="deleteMessage('@msg.Id')" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- View Message Modal -->
<div class="modal fade" id="messageModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary border-opacity-25 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-white" id="modalName">Mesaj Detayı</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <div class="bg-dark-soft p-3 rounded-3 text-secondary small mb-3" style="white-space: pre-wrap;" id="modalContent">
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const messageModal = new bootstrap.Modal(document.getElementById('messageModal'));

        function viewMessage(id, name, content) {
            document.getElementById('modalName').textContent = name;
            document.getElementById('modalContent').textContent = content;
            messageModal.show();
        }

        function deleteMessage(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu mesaj kalıcı olarak silinecektir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, sil!',
                cancelButtonText: 'İptal',
                background: '#111827',
                color: '#f8fafc'
            }).then((result) => {
                if (result.isConfirmed) {
                    const params = new URLSearchParams();
                    params.append('id', id);

                    fetch('/Home/DeleteMessage', {
                        method: 'POST',
                        body: params,
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        }
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('row-' + id).remove();
                            Swal.fire({
                                title: 'Silindi!',
                                text: 'Mesaj başarıyla silindi.',
                                icon: 'success',
                                background: '#111827',
                                color: '#f8fafc'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
