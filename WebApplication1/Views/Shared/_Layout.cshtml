@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyShop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body style="background:#0f172a;color:#e2e8f0;">

    <nav class="navbar navbar-expand-lg navbar-dark px-4" style="background:#1e293b;">
        <a class="navbar-brand fw-bold" href="/Home/Index">🛍 MyShop</a>

        <div class="ms-auto d-flex gap-3 align-items-center">

            @if (Context.Session.GetString("UserEmail") != null)
            {
                <a href="/Name/Index" class="text-light">İsim Yönetimi</a>
                <a href="/Product/Index" class="text-light">Ürünler</a>
                <a href="/Cart/Index" class="text-light">Sepetim</a>
                <a href="/Order/MyOrders" class="text-light">Siparişlerim</a>
                <a href="/Home/Technologies" class="text-light">Teknolojiler</a>
                <a href="/Home/Privacy" class="text-light">Privacy</a>

                <span class="text-info">👋 @Context.Session.GetString("Username")</span>
                <a href="/Auth/Logout" class="btn btn-danger btn-sm">Çıkış</a>
            }
            else
            {
                <a href="/Product/Index" class="text-light">Ürünler</a>
                <a href="/Home/Technologies" class="text-light">Teknolojiler</a>
                <a href="/Home/Privacy" class="text-light">Privacy</a>

                <a href="/Auth/Login" class="btn btn-primary btn-sm">Giriş</a>
                <a href="/Auth/Register" class="btn btn-success btn-sm">Kayıt</a>
            }

        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>



    @RenderSection("Scripts", required: false)

</body>
</html>