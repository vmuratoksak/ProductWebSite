<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NameManager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container">

            <!-- LOGO / BRAND -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                NameManager
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <!-- SOL MENÜ -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Ana Sayfa
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Hello" asp-action="Index">
                            İsim Yönetimi
                        </a>
                    </li>

                    <!-- DROPDOWN -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown">
                            Özellikler
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">CRUD İşlemleri</a></li>
                            <li><a class="dropdown-item" href="#">Validation</a></li>
                            <li><a class="dropdown-item" href="#">SQL Server</a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                            Gizlilik
                        </a>
                    </li>

                </ul>

                <!-- SAĞ TARAF -->
                <div class="d-flex">
                    <a asp-controller="Hello"
                       asp-action="Index"
                       class="btn btn-outline-light">
                        Yönetim Paneli
                    </a>
                </div>

            </div>
        </div>
    </nav>

    <!-- BODY -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-center text-light py-3 mt-5">
        <div class="container">
            © 2026 NameManager | ASP.NET Core MVC Project
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
