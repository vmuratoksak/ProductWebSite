@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyShop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #020617);
            color: #e2e8f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link-custom {
            color: #cbd5e1;
            font-weight: 500;
            transition: 0.3s ease;
        }

            .nav-link-custom:hover {
                color: #38bdf8;
                transform: translateY(-2px);
            }

        .user-badge {
            background: rgba(56,189,248,0.15);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 14px;
        }

        .btn-danger {
            border-radius: 20px;
        }

        .dashboard-wrapper {
            margin-top: 60px;
        }

        .card-modern {
            background: rgba(30,41,59,0.7);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            transition: 0.3s;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

            .card-modern:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            }

            .card-modern h3 {
                font-size: 32px;
                color: #38bdf8;
            }

        #google_translate_element {
            margin-right: 15px;
        }

    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4 py-3">
        <a class="navbar-brand fw-bold" href="/Home/Index">🛍 MyShop</a>

        <div class="ms-auto d-flex gap-4 align-items-center">

            <!-- GOOGLE TRANSLATE -->
            <div id="google_translate_element"></div>

            @if (Context.Session.GetString("UserEmail") != null)
            {
                <a href="/Name/Index" class="nav-link-custom">İsim Yönetimi</a>
                <a href="/Product/Index" class="nav-link-custom">Ürünler</a>
                <a href="/Cart/Index" class="nav-link-custom">Sepetim</a>
                <a href="/Order/MyOrders" class="nav-link-custom">Siparişlerim</a>
                <a href="/Home/Technologies" class="nav-link-custom">Teknolojiler</a>
                <a href="/Home/Privacy" class="nav-link-custom">Privacy</a>

                <span class="user-badge">
                    👋 @Context.Session.GetString("Username")
                </span>

                <a href="/Auth/Logout" class="btn btn-danger btn-sm px-3">
                    Çıkış
                </a>
            }
            else
            {
                <a href="/Auth/Login" class="btn btn-primary btn-sm px-3">Giriş</a>
                <a href="/Auth/Register" class="btn btn-success btn-sm px-3">Kayıt</a>
            }
        </div>
    </nav>

    <div class="container dashboard-wrapper">
        @RenderBody()
    </div>

    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'tr'
            }, 'google_translate_element');
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>