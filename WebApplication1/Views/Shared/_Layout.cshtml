@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - E-Ticaret</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #0f172a;
            color: #e2e8f0;
        }

        .navbar {
            background: #1e293b;
        }

        .card-premium {
            background: #1e293b;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 0 25px rgba(0,0,0,0.4);
            transition: 0.3s;
        }

            .card-premium:hover {
                transform: translateY(-5px);
            }

        .btn-primary {
            background: #3b82f6;
            border: none;
        }

        .btn-success {
            background: #10b981;
            border: none;
        }

        .btn-danger {
            background: #ef4444;
            border: none;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <a class="navbar-brand fw-bold" href="/Home/Index">🛍 MyShop</a>

        <div class="ms-auto d-flex gap-3 align-items-center">
			<a href="/Hello/Index" class="text-light">Isim Yonetimi</a>
            <a href="/Product/Index" class="text-light">Ürünler</a>
            <a href="/Cart/Index" class="text-light">Sepetim</a>
            <a href="/Order/MyOrders" class="text-light">Siparişlerim</a>
            <a href="/Home/Technologies" class="text-light">Teknolojiler</a>
            <a href="/Home/Privacy" class="text-light">Privacy</a>

            @if (Context.Session.GetString("UserEmail") == null)
            {
                <a href="/Auth/Login" class="btn btn-primary btn-sm">Giriş</a>
                <a href="/Auth/Register" class="btn btn-success btn-sm">Kayıt</a>
            }
            else
            {
                <span>👋 @Context.Session.GetString("Username")</span>
                <a href="/Auth/Logout" class="btn btn-danger btn-sm">Çıkış</a>
            }

        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>
