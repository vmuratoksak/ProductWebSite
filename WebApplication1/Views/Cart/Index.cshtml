@using WebApplication1.Models.ViewModels
@model List<CartViewModel>

@{
    ViewData["Title"] = "Sepetim";
}

<h2 class="mb-4">🛒 Sepetim</h2>

@if (!Model.Any())
{
    <div class="card-premium">
        Sepetiniz boş.
    </div>
}
else
{
    foreach (var item in Model)
    {
        <div class="card-premium mb-3 d-flex justify-content-between align-items-center">

            <div>
                <h5>@item.ProductName</h5>
                <div>Fiyat: @item.Price ₺</div>
                <div>Adet: @item.Quantity</div>
                <div class="text-success fw-bold">
                    Toplam: @item.TotalPrice ₺
                </div>
            </div>

            <div>
                <a href="/Cart/Increase/@item.CartId" class="btn btn-success btn-sm">+</a>
                <a href="/Cart/Decrease/@item.CartId" class="btn btn-warning btn-sm">-</a>
                <a href="/Cart/Remove/@item.CartId" class="btn btn-danger btn-sm">Sil</a>
            </div>

        </div>
    }

    <div class="card-premium text-end mt-3">
        <h4>Genel Toplam: @ViewBag.GrandTotal ₺</h4>
        <a href="/Cart/Checkout" class="btn btn-primary mt-2">Siparişi Tamamla</a>
    </div>
}
