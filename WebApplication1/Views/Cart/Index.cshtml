@model List<WebApplication1.Models.CartViewModel>

<h2>Sepetim</h2>

<table class="table table-dark">
    <thead>
        <tr>
            <th>Ürün</th>
            <th>Fiyat</th>
            <th>Adet</th>
            <th>Toplam</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Price ₺</td>
                <td>@item.Quantity</td>
                <td>@item.TotalPrice ₺</td>
                <td>
                    <a href="/Cart/Remove/@item.CartId" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<h4>Toplam Tutar: @ViewBag.GrandTotal ₺</h4>

<a href="/Cart/Checkout" class="btn btn-success">Siparişi Tamamla</a>
