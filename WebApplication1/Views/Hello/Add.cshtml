@model WebApplication1.Models.NameEntity

<h2>Yeni İsim</h2>

<form method="post">
    <div>
        <label>İsim</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn btn-success">Kaydet</button>
</form>
