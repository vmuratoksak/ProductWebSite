@model WebApplication1.Models.HelloIndexViewModel
@{
    ViewData["Title"] = "İsim Yönetimi";
}

<h2>İsim Listesi</h2>

<a asp-action="Add" class="btn btn-success mb-3">+ Yeni İsim</a>

<form method="get" class="mb-3">
    <input type="text" name="search" value="@Model.Search" placeholder="İsim ara..." />
    <button type="submit" class="btn btn-primary">Ara</button>
</form>

<table class="table table-dark">
    <tr>
        <th>İsim</th>
        <th>Oluşturma</th>
        <th>Güncelleme</th>
        <th>İşlem</th>
    </tr>

    @foreach (var item in Model.Names)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
            </td>
        </tr>
    }
</table>

<div>
    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        <a asp-action="Index" asp-route-page="@i" asp-route-search="@Model.Search"
           class="btn btn-secondary @(i == Model.CurrentPage ? "active" : "")">
            @i
        </a>
    }
</div>
