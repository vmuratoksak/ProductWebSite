@model WebApplication1.Models.HelloIndexViewModel

@{
    ViewData["Title"] = "İsim Yönetimi";
}

<h2 class="mb-4">👤 İsim Yönetimi</h2>

<div class="card card-modern p-4 mb-4">
    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6">
                <input asp-for="NewName.Name"
                       class="form-control"
                       placeholder="Yeni isim girin..." />
                <span asp-validation-for="NewName.Name" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary w-100">Ekle</button>
            </div>
        </div>
    </form>
</div>

<div class="card card-modern p-3">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>İsim</th>
                <th>Oluşturma</th>
                <th>Güncelleme</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Names)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.CreatedAt</td>
                    <td>@item.UpdatedAt</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">Düzenle</a>

                        <form asp-action="Delete" asp-route-id="@item.Id"
                              method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-danger">
                                Sil
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
