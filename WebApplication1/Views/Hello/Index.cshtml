@model WebApplication1.Models.HelloIndexViewModel

@{
    ViewData["Title"] = "İsim Listesi";
}

<div class="container mt-4">

    <h2>İsim Listesi</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">
        Yeni İsim Ekle
    </a>

    <!-- ARAMA -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text"
                   name="searchTerm"
                   value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="İsim ara..." />
            <button class="btn btn-outline-secondary">Ara</button>
        </div>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>İsim</th>
                <th>Oluşturulma</th>
                <th>Güncellenme</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Names)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-danger">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>
