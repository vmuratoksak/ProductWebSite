@model List<WebApplication1.Models.NameEntity>
@{
    ViewData["Title"] = "İsim Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👤 İsim Yönetimi</h2>
    <a href="/Hello/Add" class="btn btn-success">Yeni İsim</a>
</div>

@if (!Model.Any())
{
    <div class="card-premium">
        Henüz isim eklenmemiş.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card-premium">
                    <h5>@item.Name</h5>
                    <small class="text-secondary">
                        Eklenme: @item.CreatedAt
                    </small>

                    <div class="mt-3 d-flex justify-content-between">
                        <a href="/Hello/Edit/@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                        <a href="/Hello/Delete/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
