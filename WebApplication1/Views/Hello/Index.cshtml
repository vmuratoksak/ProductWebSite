@model WebApplication1.Models.HelloIndexViewModel

@{
    ViewData["Title"] = "İsim Yönetimi";
}

<div class="row">

    <!-- İsim Ekleme -->
    <div class="col-md-5">
        <div class="card p-4 shadow mb-4">

            <h5>Yeni İsim Ekle</h5>
            <hr />

            <form asp-action="Add" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">İsim</label>
                    <input asp-for="NewName" class="form-control" />
                    <span asp-validation-for="NewName" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    ➕ Ekle
                </button>
            </form>

        </div>
    </div>


    <!-- Liste ve Arama -->
    <div class="col-md-7">

        <div class="card p-4 shadow mb-4">

            <h5>İsim Ara</h5>
            <hr />

            <form method="get">
                <div class="input-group">
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="İsim ara..." />
                    <button class="btn btn-warning">Ara</button>
                </div>
            </form>

        </div>


        <div class="card p-4 shadow">

            <h5>Kayıtlı İsimler</h5>
            <hr />

            @if (Model.Names != null && Model.Names.Any())
            {
                <ul class="list-group list-group-flush">

                    @foreach (var item in Model.Names)
                    {
                        <li class="list-group-item bg-dark text-light d-flex justify-content-between align-items-center">

                            <div>
                                <strong>@item.Name</strong>

                                <div style="font-size: 12px; color: #94a3b8;">
                                    Oluşturma: @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                    <br />
                                    Güncelleme:
                                    @(item.UpdatedAt == DateTime.MinValue
                                                                ? "-"
                                                                : item.UpdatedAt.ToString("dd.MM.yyyy HH:mm"))
                        </div>
                    </div>

                            <div>
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning">
                                    Düzenle
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">
                                    Sil
                                </a>
                            </div>

                        </li>
                                }

                </ul>
            }
            else
            {
                <div class="alert alert-secondary">
                    Henüz kayıt bulunamadı.
                </div>
            }

        </div>

    </div>

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
