@model WebApplication1.Models.HelloViewModel

@{
    ViewData["Title"] = "Hello";
}

<h2>@Model.Message</h2>

<form asp-action="Index" asp-controller="Hello" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-2">
        <label>Adınız:</label><br />
        <input asp-for="Name" class="form-control" style="max-width:300px;" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-secondary">Gönder</button>
</form>

<p class="mt-3">
    Sistem Tarihi: <strong>@Model.Date</strong>
</p>

<hr />

@if (Model.Names != null && Model.Names.Any())
{
    <h4>Eklenen İsimler</h4>

    <ul>
        @foreach (var item in Model.Names)
        {
            <li>
                @item
                <a asp-action="Delete"
                   asp-route-name="@item"
                   style="color:red; margin-left:10px">
                    Sil
                </a>
            </li>
        }
    </ul>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
