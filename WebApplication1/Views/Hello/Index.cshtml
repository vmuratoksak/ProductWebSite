@model WebApplication1.Models.HelloIndexViewModel

<h2>İsim Ekle</h2>

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()

    <div>
        <input asp-for="NewName.Name" class="form-control" style="max-width:300px" />
        <span asp-validation-for="NewName.Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Ekle</button>
</form>

<hr />

<h3>Kayıtlı İsimler</h3>

<ul>
    @foreach (var item in Model.Names)
    {
        <li>
            <strong>@item.Name</strong>
            <small>(@item.CreatedAt)</small>
            |
            <a asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
            |
            <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger">Sil</a>
        </li>
    }
</ul>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
