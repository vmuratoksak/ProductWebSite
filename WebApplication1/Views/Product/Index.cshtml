@model List<WebApplication1.Models.Entities.ProductEntity>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Ürünler";
}

<h2 class="fw-bold mb-4">📦 Ürünler</h2>

@if (Context.Session.GetString("UserRole") == "Admin")
{
    <div class="mb-4">
        <a href="/Product/Add" class="btn btn-success">
            ➕ Yeni Ürün Ekle
        </a>
    </div>
}

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-lg h-100"
                 style="background:#1e293b;color:#e2e8f0;border-radius:15px;">

                <h4>@item.Name</h4>

                <span class="badge bg-info mb-2">
                    Stok: @item.Stock
                </span>

                <h5 class="text-success mb-3">
                    @item.Price ₺
                </h5>

                @* USER NOT LOGGED IN *@
                @if (Context.Session.GetString("UserId") == null)
                {
                    <a href="/Auth/Login"
                       class="btn btn-warning btn-sm w-100">
                        Giriş Yap
                    </a>
                }

                @* ADMIN *@
                else if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <div class="d-flex flex-column gap-2">

                        <div class="d-flex gap-2">
                            <a href="/Product/IncreaseStock/@item.Id"
                               class="btn btn-success btn-sm w-50">
                                ➕ Stok
                            </a>

                            <a href="/Product/DecreaseStock/@item.Id"
                               class="btn btn-secondary btn-sm w-50">
                                ➖ Stok
                            </a>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="/Product/Edit/@item.Id"
                               class="btn btn-warning btn-sm w-50">
                                ✏️ Düzenle
                            </a>

                            <a href="/Product/Delete/@item.Id"
                               class="btn btn-danger btn-sm w-50">
                                🗑 Sil
                            </a>
                        </div>

                    </div>
                }

                @* NORMAL USER *@
                else
                {
                    if (item.Stock > 0)
                    {
                        <a href="/Cart/Add?productId=@item.Id"
                           class="btn btn-primary btn-sm w-100">
                            🛒 Sepete Ekle
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm w-100" disabled>
                            Stok Yok
                        </button>
                    }
                }

            </div>
        </div>
    }
</div>