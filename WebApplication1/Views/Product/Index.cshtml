@model List<WebApplication1.Models.Entities.ProductEntity>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Ürünler";
}

<h2 class="fw-bold mb-4">📦 Ürünler</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-lg h-100"
                 style="background:#1e293b;color:#e2e8f0;border-radius:15px;">

                <h4>@item.Name</h4>

                <span class="badge bg-info mb-2">
                    Stok: @item.Stock
                </span>

                <h5 class="text-success mb-3">
                    @item.Price ₺
                </h5>

                @if (Context.Session.GetString("UserId") != null)
                {
                    if (item.Stock > 0)
                    {
                        <a href="/Cart/Add?productId=@item.Id"
                           class="btn btn-primary btn-sm w-100">
                            🛒 Sepete Ekle
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm w-100" disabled>
                            Stok Yok
                        </button>
                    }
                }
                else
                {
                    <a href="/Auth/Login"
                       class="btn btn-warning btn-sm w-100">
                        Giriş Yap
                    </a>
                }
            </div>
        </div>
    }
</div>