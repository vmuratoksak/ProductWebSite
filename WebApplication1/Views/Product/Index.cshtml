@model List<WebApplication1.Models.ProductEntity>

<h2>Ürün Listesi</h2>

@if (Context.Session.GetString("UserRole") == "Admin")
{
    <a asp-controller="Product"
       asp-action="Add"
       class="btn btn-success mb-3">
        Yeni Ürün
    </a>
}

<table class="table table-dark">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Fiyat</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a asp-controller="Product"
                           asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Sil
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
