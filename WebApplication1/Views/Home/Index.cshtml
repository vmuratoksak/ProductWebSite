@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Mini MVC CRUD Projesi</h1>
    <p class="lead text-muted mt-3">
        ASP.NET Core MVC + Entity Framework Core kullanılarak geliştirilmiştir.
    </p>
</div>

<hr class="my-5" />

<div class="row text-center">

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">✔ CRUD İşlemleri</h5>
                <p class="card-text">
                    İsim ekleme, listeleme, güncelleme ve silme işlemleri yapılmaktadır.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">✔ Validation</h5>
                <p class="card-text">
                    Boş geçilemez alan kontrolü ve 50 karakter sınırı uygulanmıştır.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">✔ Database</h5>
                <p class="card-text">
                    SQL Server ve EF Core Migration sistemi kullanılmıştır.
                </p>
            </div>
        </div>
    </div>

</div>

<div class="text-center mt-4">
    <a asp-controller="Hello" asp-action="Index" class="btn btn-dark btn-lg">
        İsim Yönetim Paneline Git
    </a>
</div>
