@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">

    <!-- HERO -->
    <div class="hero-box text-center">
        <h1 class="display-4 fw-bold mb-3">
            Modern ASP.NET Core MVC Projesi
        </h1>

        <p class="lead mb-4">
            Entity Framework Core ile veritabanı bağlantılı,
            Validation destekli ve tam CRUD yapısına sahip modern web uygulaması.
        </p>

        <a asp-controller="Hello" asp-action="Index"
           class="btn btn-light btn-lg">
            İsim Yönetim Paneli
        </a>
    </div>

    <!-- ÖZELLİKLER -->
    <div class="row mt-5 text-center">

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <h4 class="text-warning">CRUD İşlemleri</h4>
                <p>
                    Create, Read, Update, Delete işlemleri
                    Entity Framework Core ile yapılmaktadır.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <h4 class="text-info">Validation</h4>
                <p>
                    50 karakter sınırı ve boş alan kontrolü
                    hem client hem server tarafında uygulanmaktadır.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <h4 class="text-success">SQL Server</h4>
                <p>
                    Migration sistemi ile veritabanı otomatik oluşturulmaktadır.
                </p>
            </div>
        </div>

    </div>

    <!-- TEKNOLOJİLER -->
    <div class="text-center mt-4">
        <h5 class="mb-3">Kullanılan Teknolojiler</h5>

        <span class="badge bg-light text-dark p-2 m-1">ASP.NET Core 8</span>
        <span class="badge bg-secondary p-2 m-1">MVC</span>
        <span class="badge bg-primary p-2 m-1">Entity Framework</span>
        <span class="badge bg-success p-2 m-1">SQL Server</span>
        <span class="badge bg-warning text-dark p-2 m-1">Bootstrap 5</span>
    </div>

</div>
