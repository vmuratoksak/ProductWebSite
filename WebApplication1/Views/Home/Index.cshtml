@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center" style="margin-top: 50px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <h1 class="display-4" style="color: #007bff;">Merhaba! 👋</h1>
    <p style="font-size: 1.2rem; color: #555;">
        Bu benim ilk <strong>.NET MVC</strong> projem.
    </p>

    <div style="background-color: #f8f9fa; padding: 20px; border-radius: 10px; display: inline-block; border: 1px solid #dee2e6;">
        <p style="margin-bottom: 5px; color: #6c757d;">Sistem Kayıt Tarihi:</p>
        <h3 style="color: #28a745;">@DateTime.Now.ToString("dd MMMM yyyy, dddd")</h3>
    </div>
</div>