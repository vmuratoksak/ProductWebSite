@model WebApplication1.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (Context.Session.GetString("Username") != null)
{
    <div class="card-premium mb-4 p-3 text-light"
         style="background:rgba(30,41,59,0.6); border-radius:15px;">
        👋 Hoşgeldin @Context.Session.GetString("Username")
    </div>
}

<h2 class="mb-4">📊 Dashboard</h2>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card-modern">
            <h3>@Model.TotalNames</h3>
            <p>Toplam İsim</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-modern">
            <h3>@Model.TodayNames</h3>
            <p>Bugün Eklenen İsim</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-modern">
            <h3>@Model.TotalProducts</h3>
            <p>Toplam Ürün</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-modern">
            <h3>@Model.TotalOrders</h3>
            <p>Toplam Sipariş</p>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card-modern text-start">
            <h5>Son Güncellenen İsim</h5>
            <h4 class="text-info">@Model.LastUpdatedName</h4>
        </div>
    </div>

</div>